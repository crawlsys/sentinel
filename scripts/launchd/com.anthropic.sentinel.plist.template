<?xml version="1.0" encoding="UTF-8"?>
<!--
  launchd plist template for auto-starting the sentinel daemon on
  macOS login. Drop into ~/Library/LaunchAgents/ as:

      com.anthropic.sentinel.plist

  Then load it:

      launchctl load ~/Library/LaunchAgents/com.anthropic.sentinel.plist

  Disable / unload:

      launchctl unload ~/Library/LaunchAgents/com.anthropic.sentinel.plist

  ----- BEFORE COPYING IN PLACE: REPLACE THE PLACEHOLDERS BELOW -----

  - {{SENTINEL_BIN}}        absolute path to the `sentinel` binary
                            (e.g. /Users/you/.cargo/bin/sentinel)
  - {{HOME}}                /Users/<you>
  - {{LOG_DIR}}             /Users/<you>/Library/Logs/sentinel
-->

<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.anthropic.sentinel</string>

    <key>ProgramArguments</key>
    <array>
        <string>{{SENTINEL_BIN}}</string>
        <string>daemon</string>
        <string>--port</string>
        <string>3001</string>
    </array>

    <!-- Start at login, restart on crash. -->
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <!-- Don't thrash if the daemon keeps dying. -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <!-- Logs to a per-user log dir so `tail -F` is easy. Rotation
         is the operator's responsibility (newsyslog / logrotate). -->
    <key>StandardOutPath</key>
    <string>{{LOG_DIR}}/sentinel.out.log</string>
    <key>StandardErrorPath</key>
    <string>{{LOG_DIR}}/sentinel.err.log</string>

    <!-- HOME must be set; otherwise dirs::home_dir() (used for the
         token + PID file) breaks. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>{{HOME}}</string>
        <!-- Conservative log level so the daemon log is small but
             still useful. Set to "debug" temporarily when
             diagnosing. -->
        <key>RUST_LOG</key>
        <string>info</string>
    </dict>

    <!-- Background, no UI. -->
    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
