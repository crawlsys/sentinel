# sentinel-viz-next — operator-facing env config.
#
# Copy to `.env.production` (loaded by `next start`) or `.env.local`
# (loaded by `next dev` AND `next start`, wins over .env.production).
# Keys with the `NEXT_PUBLIC_` prefix are baked into the client
# bundle at build time — re-run `pnpm build` after changing them.
#
# Two layers wire into the dashboard:
#   1. Frontend → viz-api: NEXT_PUBLIC_VIZ_API
#   2. viz-api → AI backend: SENTINEL_LLM_PREFER + OLLAMA_HOST
#      (set in viz-api's environment, NOT here — Next.js doesn't
#      see them. Listed below for completeness so operators have
#      one canonical file describing the full env contract.)

# --- Frontend (Next.js) -----------------------------------------

# Where the browser fetches /api/graph, /api/sessions, etc.
# Must be reachable from the OPERATOR'S browser (not the Next
# server). For LAN deployments this is the host IP + port; for
# in-cluster setups, use the service DNS name.
NEXT_PUBLIC_VIZ_API=http://172.16.100.22:8082

# --- Backend (viz-api binary) -----------------------------------
# These are set in viz-api's launch environment, not Next.js.
# They are listed here as documentation only; the values below
# are the recommended defaults for nighttime / ollama-research:
#
#   export SENTINEL_LLM_PREFER=local
#   export OLLAMA_HOST=http://172.16.100.125:31435
#   export OLLAMA_MODEL=qwen3-coder:30b   # optional override
#
# `SENTINEL_LLM_PREFER`:
#   - `local` — force local Ollama. If unreachable, viz LLM
#     features (session naming, summaries) are disabled rather
#     than silently routing to OpenRouter.
#   - `cloud` — force OpenRouter. Requires OPENROUTER_API_KEY.
#   - `auto` (default) — probe local at OLLAMA_HOST/v1/models;
#     fall back to OpenRouter if local doesn't respond.
#
# `OLLAMA_HOST` — base URL of the local OpenAI-compatible LLM.
# Trailing `/v1` is appended automatically; don't include it here.
# Defaults to http://localhost:11434.
#
# `OLLAMA_MODEL` — model ID served by the backend. Defaults to
# `qwen3-coder:30b`. Must match a model loaded on the host
# (`ollama pull qwen3-coder:30b` or whatever's in vllm's config).
