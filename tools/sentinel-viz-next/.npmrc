# Strict version pinning: every dep is exact, no ^ / ~ ranges.
# Enforced because supply-chain compromise is real and "auto-bump"
# semver is the attacker's friend. Pin or GTFO.
save-exact=true
save-prefix=
# Fail loudly if node/pnpm version doesn't match package.json engines.
engine-strict=true
# Refuse to install if the lockfile is out of sync. CI and local must
# both go through `pnpm install --frozen-lockfile` semantics by default.
frozen-lockfile=true
# Don't auto-install peer deps silently; surface them so we audit.
auto-install-peers=false
# Allowlist of packages whose install/postinstall scripts may run.
# Everything else is sandboxed by default (pnpm 11+ default behavior).
# Add to this list only after auditing what the package's scripts do.
only-built-dependencies[]=sharp
only-built-dependencies[]=unrs-resolver
