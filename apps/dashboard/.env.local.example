# Sentinel Dashboard env template — copy to .env.local
# The dashboard talks to the sentinel daemon REST API.

# Sentinel daemon URL (port 3002 once SENTINEL-31 lands; for now it conflicts
# with `pnpm dev` which uses 3001). Override with whatever port the daemon
# runs on locally.
NEXT_PUBLIC_SENTINEL_API_URL=http://localhost:3002

# Optional: API auth token for the dashboard -> daemon connection.
# Leave blank during local dev unless the daemon enforces auth.
SENTINEL_API_TOKEN=
